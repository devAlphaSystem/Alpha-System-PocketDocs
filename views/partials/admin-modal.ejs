<div class="admin-modal" id="adminModal" hidden>
  <div class="admin-modal-backdrop" data-modal-close></div>
  <div class="admin-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="adminModalTitle" aria-describedby="adminModalMessage" tabindex="-1">
    <div class="admin-modal-header">
      <h3 class="admin-modal-title" id="adminModalTitle">Confirm Action</h3>
    </div>
    <div class="admin-modal-body">
      <p class="admin-modal-message" id="adminModalMessage"></p>
    </div>
    <div class="admin-modal-actions">
      <button type="button" class="btn btn-outline" id="adminModalCancel">Cancel</button>
      <button type="button" class="btn btn-danger" id="adminModalConfirm">Confirm</button>
    </div>
  </div>
</div>
