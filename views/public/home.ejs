<div class="home-hero">
  <div class="hero-content">
    <h1>
      <% const _ss = typeof siteSettings !== 'undefined' ? siteSettings : null; %>
      <% if (_ss) { %>
      <span class="brand-word-pocket"><%= _ss.heroWord1 %></span><span class="brand-word-docs"><%= _ss.heroWord2 %></span>
      <% } else if (siteName === 'PocketDocs') { %>
      <span class="brand-word-pocket">Pocket</span><span class="brand-word-docs">Docs</span>
      <% } else { %>
      <%= siteName %>
      <% } %>
    </h1>
    <p class="hero-subtitle"><%= (_ss && _ss.heroSubtitle) ? _ss.heroSubtitle : 'Beautiful, self-hosted documentation for your projects.' %></p>
  </div>
</div>

<div class="home-projects">
  <% if (projects.length === 0) { %>
  <div class="empty-state">
    <div class="empty-icon"><i class="ph ph-book-open-text"></i></div>
    <h2>No public projects yet</h2>
    <p>Documentation projects will appear here once published.</p>
  </div>
  <% } else { %>
  <div class="project-grid">
    <% for (const proj of projects) { %>
    <a href="/docs/<%= proj.slug %>" class="project-card">
      <div class="project-card-header">
        <% if (proj.logo) { %>
        <img src="<%= sitePbUrl %>/api/files/projects/<%= proj.id %>/<%= proj.logo %>" alt="" class="project-logo">
        <% } else { %>
        <div class="project-logo-placeholder">
          <%= proj.name.charAt(0).toUpperCase() %>
        </div>
        <% } %>
      </div>
      <div class="project-card-body">
        <h3><%= proj.name %></h3>
        <% if (proj.description) { %>
        <p><%= proj.description %></p>
        <% } %>
      </div>
      <div class="project-card-footer">
        <span class="project-slug">/<%= proj.slug %></span>
        <i class="ph ph-arrow-right"></i>
      </div>
    </a>
    <% } %>
  </div>
  <% } %>
</div>
