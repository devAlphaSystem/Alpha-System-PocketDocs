<div class="project-landing">
  <div class="project-hero">
    <div class="project-hero-content">
      <% if (project.logo) { %>
      <img src="<%= sitePbUrl %>/api/files/projects/<%= project.id %>/<%= project.logo %>" alt="" class="project-hero-logo">
      <% } %>
      <h1><%= project.name %></h1>
      <% if (project.description) { %>
      <p class="project-hero-desc"><%= project.description %></p>
      <% } %>
      <% if (defaultVersion) { %>
      <a href="/docs/<%= project.slug %>/<%= defaultVersion.slug %>" class="btn btn-primary btn-lg">
        <i class="ph ph-book-open"></i> Read the Docs
      </a>
      <% } %>
    </div>
  </div>

  <% if (versions.length > 0) { %>
  <div class="project-versions-section">
    <h2>Versions</h2>
    <div class="versions-grid">
      <% for (const ver of versions) { %>
      <a href="/docs/<%= project.slug %>/<%= ver.slug %>" class="version-tile">
        <span class="version-label"><%= ver.label %></span>
        <i class="ph ph-arrow-right"></i>
      </a>
      <% } %>
    </div>
  </div>
  <% } %>
</div>
