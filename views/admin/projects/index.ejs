<div class="projects-page">
  <div class="page-header page-header-compact">
    <% if (user.role === 'owner' || user.role === 'admin') { %>
    <a href="/admin/projects/create" class="btn btn-primary">
      <i class="ph ph-plus"></i>
      New Project
    </a>
    <% } %>
  </div>

  <% if (projects.length === 0) { %>
  <div class="empty-state">
    <div class="empty-icon"><i class="ph ph-folders"></i></div>
    <% if (typeof search !== 'undefined' && search) { %>
    <h2>No matching projects</h2>
    <p>No projects found for "<%= search %>". <a href="/admin/projects">Clear search</a></p>
    <% } else { %>
    <h2>No projects yet</h2>
    <p>Create your first documentation project.</p>
    <% } %>
  </div>
  <% } else { %>
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Project</th>
          <th>Slug</th>
          <th>Visibility</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        <% for (const proj of projects) { %>
        <tr class="row-link" data-row-link="/admin/projects/<%= proj.id %>" tabindex="0" aria-label="Open project <%= proj.name %>">
          <td>
            <div class="table-project-cell">
              <% if (proj.logo) { %>
              <img src="<%= sitePbUrl %>/api/files/projects/<%= proj.id %>/<%= proj.logo %>" alt="" class="table-avatar">
              <% } else { %>
              <div class="table-avatar-placeholder"><%= proj.name.charAt(0).toUpperCase() %></div>
              <% } %>
              <strong><%= proj.name %></strong>
            </div>
          </td>
          <td><code><%= proj.slug %></code></td>
          <td><span class="badge badge-<%= proj.visibility %>"><%= proj.visibility %></span></td>
          <td><%= new Date(proj.created).toLocaleDateString() %></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <%- include('../../partials/pagination', { pagination, search: typeof search !== 'undefined' ? search : '' }) %>
  <% } %>
</div>
