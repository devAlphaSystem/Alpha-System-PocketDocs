<div class="form-page">
  <div class="page-header">
    <div>
      <a href="/admin/projects/<%= project.id %>" class="back-link"><i class="ph ph-arrow-left"></i> <%= project.name %></a>
    </div>
    <form method="POST" action="/admin/projects/<%= project.id %>/delete" class="inline-form" onsubmit="return confirm('Delete this project and all its content? This cannot be undone.')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-danger"><i class="ph ph-trash"></i> Delete</button>
    </form>
  </div>

  <div class="page-header sub-header">
    <h2>Edit Project</h2>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><i class="ph ph-warning-circle"></i> <%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success"><i class="ph ph-check-circle"></i> <%= success %></div>
  <% } %>

  <form method="POST" action="/admin/projects/<%= project.id %>" class="card form-card" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group">
      <label for="name">Project name <span class="required">*</span></label>
      <input type="text" id="name" name="name" value="<%= project.name %>" required maxlength="100">
    </div>

    <div class="form-group">
      <label for="slug">Slug <span class="required">*</span></label>
      <div class="input-prefix-wrap">
        <span class="input-prefix">/docs/</span>
        <input type="text" id="slug" name="slug" value="<%= project.slug %>" required maxlength="80" pattern="[a-z0-9]+(?:-[a-z0-9]+)*">
      </div>
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="3" maxlength="500"><%= project.description || '' %></textarea>
    </div>

    <div class="form-group">
      <label for="visibility">Visibility</label>
      <select id="visibility" name="visibility">
        <option value="public"<%= project.visibility === 'public' ? ' selected' : '' %>>Public</option>
        <option value="private"<%= project.visibility === 'private' ? ' selected' : '' %>>Private</option>
      </select>
    </div>

    <div class="form-actions">
      <a href="/admin/projects/<%= project.id %>" class="btn btn-outline">Cancel</a>
      <button type="submit" class="btn btn-primary"><i class="ph ph-floppy-disk"></i> Save Changes</button>
    </div>
  </form>
</div>

