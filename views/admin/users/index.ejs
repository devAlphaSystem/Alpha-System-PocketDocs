<div class="form-page">
  <div class="page-header">
    <div>
      <a href="/admin/projects" class="back-link"><i class="ph ph-arrow-left"></i> Projects</a>
    </div>
    <button type="button" class="btn btn-primary" onclick="document.getElementById('createUserModal').showModal()">
      <i class="ph ph-user-plus"></i>
      New User
    </button>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><i class="ph ph-warning-circle"></i> <%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success"><i class="ph ph-check-circle"></i> <%= success %></div>
  <% } %>

  <% if (users.length === 0) { %>
  <div class="empty-state">
    <div class="empty-icon"><i class="ph ph-users"></i></div>
    <h2>No users yet</h2>
    <p>Create your first user account.</p>
  </div>
  <% } else { %>
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Created</th>
          <th class="table-actions-col">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (const u of users) { %>
        <tr>
          <td>
            <div class="table-project-cell">
              <div class="table-avatar-placeholder"><%= (u.name || u.email).charAt(0).toUpperCase() %></div>
              <strong><%= u.name || '—' %></strong>
              <% if (u.id === user.id) { %><span class="badge badge-public">you</span><% } %>
            </div>
          </td>
          <td><%= u.email %></td>
          <td><span class="badge badge-<%= u.role === 'owner' ? 'public' : u.role === 'admin' ? 'private' : 'public' %>"><%= u.role %></span></td>
          <td><%= new Date(u.created).toLocaleDateString() %></td>
          <td class="table-actions-col">
            <% if (u.role !== 'owner') { %>
            <a href="/admin/users/<%= u.id %>/edit" class="btn btn-outline btn-sm" title="Edit user">
              <i class="ph ph-pencil-simple"></i>
            </a>
            <% if (u.id !== user.id) { %>
            <form method="POST" action="/admin/users/<%= u.id %>/delete" class="inline-form" data-confirm-title="Delete user?" data-confirm-message="Delete this user account? This cannot be undone." data-confirm-button="Delete" data-confirm-variant="danger">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-outline btn-sm btn-danger" title="Delete user">
                <i class="ph ph-trash"></i>
              </button>
            </form>
            <% } %>
            <% } %>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<dialog id="createUserModal" class="admin-dialog">
  <div class="dialog-content">
    <div class="dialog-header">
      <h2>Create User</h2>
      <button type="button" class="dialog-close" onclick="document.getElementById('createUserModal').close()" aria-label="Close">
        <i class="ph ph-x"></i>
      </button>
    </div>
    <form method="POST" action="/admin/users/create" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="dialog-body">
        <div class="form-group">
          <label for="create-name">Full name <span class="required">*</span></label>
          <input type="text" id="create-name" name="name" required maxlength="100" placeholder="Jane Doe">
        </div>
        <div class="form-group">
          <label for="create-email">Email <span class="required">*</span></label>
          <input type="email" id="create-email" name="email" required maxlength="255" placeholder="user@example.com">
        </div>
        <div class="form-group">
          <label for="create-role">Role <span class="required">*</span></label>
          <select id="create-role" name="role" required>
            <option value="editor">Editor</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="form-group">
          <label for="create-password">Password <span class="required">*</span></label>
          <input type="password" id="create-password" name="password" required minlength="8" maxlength="256" placeholder="Min 8 characters">
        </div>
        <div class="form-group">
          <label for="create-passwordConfirm">Confirm password <span class="required">*</span></label>
          <input type="password" id="create-passwordConfirm" name="passwordConfirm" required minlength="8" maxlength="256" placeholder="Repeat password">
        </div>
      </div>
      <div class="dialog-footer">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('createUserModal').close()">Cancel</button>
        <button type="submit" class="btn btn-primary"><i class="ph ph-user-plus"></i> Create User</button>
      </div>
    </form>
  </div>
</dialog>

<% if (editUser) { %>
<dialog id="editUserModal" class="admin-dialog">
  <div class="dialog-content">
    <div class="dialog-header">
      <h2>Edit User</h2>
      <a href="/admin/users" class="dialog-close" aria-label="Close">
        <i class="ph ph-x"></i>
      </a>
    </div>
    <form method="POST" action="/admin/users/<%= editUser.id %>/update" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="dialog-body">
        <div class="form-group">
          <label for="edit-name">Full name <span class="required">*</span></label>
          <input type="text" id="edit-name" name="name" required maxlength="100" value="<%= editUser.name %>">
        </div>
        <div class="form-group">
          <label for="edit-email">Email <span class="required">*</span></label>
          <input type="email" id="edit-email" name="email" required maxlength="255" value="<%= editUser.email %>">
        </div>
        <div class="form-group">
          <label for="edit-role">Role <span class="required">*</span></label>
          <select id="edit-role" name="role" required>
            <option value="editor" <%= editUser.role === 'editor' ? 'selected' : '' %>>Editor</option>
            <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
          </select>
        </div>
        <div class="form-group">
          <label for="edit-password">New password</label>
          <input type="password" id="edit-password" name="password" minlength="8" maxlength="256" placeholder="Leave blank to keep current">
        </div>
        <div class="form-group">
          <label for="edit-passwordConfirm">Confirm new password</label>
          <input type="password" id="edit-passwordConfirm" name="passwordConfirm" minlength="8" maxlength="256" placeholder="Leave blank to keep current">
        </div>
      </div>
      <div class="dialog-footer">
        <a href="/admin/users" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary"><i class="ph ph-floppy-disk"></i> Save Changes</button>
      </div>
    </form>
  </div>
</dialog>
<script>
  (function () {
    var editModal = document.getElementById('editUserModal');
    if (editModal && !editModal.open) {
      editModal.showModal();
    }
  })();
</script>
<% } %>
