<div class="editor-page">
  <div class="page-header">
    <div>
      <a href="/admin/projects/<%= project.id %>/versions/<%= version.id %>/pages" class="back-link"><i class="ph ph-arrow-left"></i> Pages</a>
    </div>
    <div class="header-actions">
      <% if (typeof page !== 'undefined' && page) { %>
      <% if (typeof simpleMode !== 'undefined' && simpleMode) { %>
      <a href="/docs/<%= project.slug %>/<%= page.slug %>" class="btn btn-outline" target="_blank"><i class="ph ph-arrow-square-out"></i> Preview</a>
      <% } else { %>
      <a href="/docs/<%= project.slug %>/<%= version.slug %>/<%= page.slug %>" class="btn btn-outline" target="_blank"><i class="ph ph-arrow-square-out"></i> Preview</a>
      <% } %>
      <% } %>
      <button type="submit" form="pageForm" class="btn btn-primary"><i class="ph ph-floppy-disk"></i> Save</button>
    </div>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><i class="ph ph-warning-circle"></i> <%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success"><i class="ph ph-check-circle"></i> <%= success %></div>
  <% } %>

  <form id="pageForm" method="POST" action="<%= typeof page !== 'undefined' && page ? '/admin/projects/' + project.id + '/versions/' + version.id + '/pages/' + page.id : '/admin/projects/' + project.id + '/versions/' + version.id + '/pages/new' %>" class="editor-form" data-preview-url="/admin/projects/<%= project.id %>/versions/<%= version.id %>/pages/preview" data-validate-url="/admin/projects/<%= project.id %>/versions/<%= version.id %>/pages/validate-links" data-page-slug="<%= typeof page !== 'undefined' && page ? page.slug : '' %>" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="editor-meta">
      <div class="form-row">
        <div class="form-group flex-2">
          <label for="title">Title <span class="required">*</span></label>
          <input type="text" id="title" name="title" placeholder="Getting Started" required maxlength="200" value="<%= typeof page !== 'undefined' && page ? page.title : (typeof formValues !== 'undefined' && formValues && formValues.title ? formValues.title : '') %>">
        </div>
        <div class="form-group flex-1">
          <label for="slug">Slug</label>
          <input type="text" id="slug" name="slug" placeholder="getting-started" maxlength="200" value="<%= typeof page !== 'undefined' && page ? page.slug : (typeof formValues !== 'undefined' && formValues && formValues.slug ? formValues.slug : '') %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="icon">Icon (<a href="https://phosphoricons.com/#toolbar" target="_blank" rel="noopener noreferrer">Phosphor</a>)</label>
          <input type="text" id="icon" name="icon" placeholder="book-open" maxlength="50" value="<%= typeof page !== 'undefined' && page ? (page.icon || '') : (typeof formValues !== 'undefined' && formValues && formValues.icon ? formValues.icon : '') %>">
        </div>
        <div class="form-group">
          <label for="parent">Parent page</label>
          <select id="parent" name="parent">
            <option value="">None (top-level)</option>
            <% if (typeof pages !== 'undefined') { %>
              <% for (const p of pages) { %>
                <% if (typeof page === 'undefined' || !page || p.id !== page.id) { %>
                <option value="<%= p.id %>"<%= (typeof page !== 'undefined' && page && page.parent === p.id) ? ' selected' : '' %>><%= p.title %></option>
                <% } %>
              <% } %>
            <% } %>
          </select>
        </div>
      </div>
    </div>

    <div class="link-checker-panel" id="linkCheckerPanel" style="display: none;">
      <div class="link-checker-header">
        <div class="link-checker-title">
          <i class="ph ph-link-break"></i>
          <span id="linkCheckerTitle">Checking links...</span>
        </div>
        <button type="button" class="link-checker-close" id="linkCheckerClose" title="Dismiss"><i class="ph ph-x"></i></button>
      </div>
      <div class="link-checker-results" id="linkCheckerResults"></div>
    </div>

    <div class="editor-content">
      <textarea id="content" name="content"><%= typeof page !== 'undefined' && page ? page.content : (typeof formValues !== 'undefined' && formValues && formValues.content ? formValues.content : '') %></textarea>
    </div>
  </form>
</div>

<script>
  var titleInput = document.getElementById('title');
  var slugInput = document.getElementById('slug');
  var iconInput = document.getElementById('icon');
  var autoSlug = !slugInput.value;
  var autoIcon = !iconInput.value;

  /**
   * Map of page-title patterns to Phosphor icon names.
   * Keys are matched case-insensitively against the trimmed title.
   */
  var PAGE_ICON_MAP = {
    'readme':          'book-open-text',
    'license':         'scales',
    'licence':         'scales',
    'changelog':       'clock-counter-clockwise',
    'contributing':    'git-pull-request',
    'code of conduct': 'handshake',
    'security':        'shield-check',
    'faq':             'question',
    'getting started': 'rocket-launch',
    'installation':    'download-simple',
    'setup':           'gear',
    'configuration':   'sliders-horizontal',
    'api':             'plugs-connected',
    'api reference':   'plugs-connected',
    'authentication':  'lock-key',
    'deployment':      'cloud-arrow-up',
    'troubleshooting': 'wrench',
    'architecture':    'tree-structure',
    'migration':       'arrows-left-right',
    'testing':         'test-tube',
    'examples':        'code',
    'tutorial':        'graduation-cap',
    'introduction':    'hand-waving',
    'overview':        'binoculars',
    'quickstart':      'lightning',
    'quick start':     'lightning',
    'upgrade':         'arrow-circle-up',
    'plugins':         'puzzle-piece',
    'extensions':      'puzzle-piece',
    'glossary':        'book-bookmark',
    'reference':       'files',
    'usage':           'book-open',
    'guide':           'compass',
    'features':        'star',
    'release notes':   'newspaper',
    'about':           'info',
    'support':         'lifebuoy',
    'contact':         'envelope-simple',
    'privacy':         'eye-slash',
    'privacy policy':  'eye-slash',
    'terms':           'file-text',
    'terms of service':'file-text',
  };

  slugInput.addEventListener('input', function() { autoSlug = false; });
  iconInput.addEventListener('input', function() { autoIcon = false; });

  titleInput.addEventListener('input', function() {
    if (autoSlug) {
      slugInput.value = titleInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }
    if (autoIcon) {
      var key = titleInput.value.trim().toLowerCase();
      iconInput.value = PAGE_ICON_MAP[key] || '';
    }
  });
</script>
