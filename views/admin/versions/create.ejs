<div class="form-page">
  <div class="page-header">
    <div>
      <a href="/admin/projects/<%= project.id %>" class="back-link"><i class="ph ph-arrow-left"></i> <%= project.name %></a>
    </div>
    <div class="header-actions">
      <a href="/admin/projects/<%= project.id %>" class="btn btn-outline">Cancel</a>
      <button type="submit" form="version-create-form" class="btn btn-primary"><i class="ph ph-plus"></i> Create Version</button>
    </div>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><i class="ph ph-warning-circle"></i> <%= error %></div>
  <% } %>

  <form method="POST" action="/admin/projects/<%= project.id %>/versions" novalidate id="version-create-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group">
      <label for="label">Version label <span class="required">*</span></label>
      <input type="text" id="label" name="label" placeholder="v2.0, Beta, Latest..." required maxlength="50" value="<%= typeof formValues !== 'undefined' && formValues && formValues.label ? formValues.label : '' %>">
      <p class="form-hint">Freeform label: e.g. "v1.0", "2024.1", "Beta"</p>
    </div>

    <div class="form-group">
      <label for="is_public">Visibility <span class="required">*</span></label>
      <select id="is_public" name="is_public">
        <option value="false"<%= typeof formValues === 'undefined' || !formValues || formValues.is_public !== 'true' ? ' selected' : '' %>>Draft</option>
        <option value="true"<%= typeof formValues !== 'undefined' && formValues && formValues.is_public === 'true' ? ' selected' : '' %>>Public</option>
      </select>
    </div>

    <% if (existingVersions && existingVersions.length > 0) { %>
    <div class="form-group">
      <label for="clone_from">Clone from existing version</label>
      <select id="clone_from" name="clone_from">
        <option value="">Start fresh (empty)</option>
        <% for (const v of existingVersions) { %>
        <option value="<%= v.id %>"<%= typeof formValues !== 'undefined' && formValues && formValues.clone_from === v.id ? ' selected' : '' %>><%= v.label %></option>
        <% } %>
      </select>
      <p class="form-hint">Clone all pages from another version to get a head start.</p>
    </div>
    <% } %>
  </form>
</div>
