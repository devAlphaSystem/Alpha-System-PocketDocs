<div class="editor-page">
  <div class="page-header">
    <div>
      <a href="/admin/projects/<%= project.id %>" class="back-link"><i class="ph ph-arrow-left"></i> <%= project.name %> / <%= version.label %></a>
    </div>
    <div class="header-actions">
      <% if (typeof changelog !== 'undefined' && changelog) { %>
      <a href="/docs/<%= project.slug %>/<%= version.slug %>/changelog" class="btn btn-outline" target="_blank"><i class="ph ph-arrow-square-out"></i> Preview</a>
      <% } %>
      <% if (user.role === 'owner' || user.role === 'admin') { %>
      <button type="submit" form="changelogForm" class="btn btn-primary"><i class="ph ph-floppy-disk"></i> Save</button>
      <% } %>
    </div>
  </div>

  <div class="page-header sub-header">
    <h2>Changelog</h2>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><i class="ph ph-warning-circle"></i> <%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success"><i class="ph ph-check-circle"></i> <%= success %></div>
  <% } %>

  <form id="changelogForm" method="POST" action="/admin/projects/<%= project.id %>/versions/<%= version.id %>/changelog" class="editor-form" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="editor-meta">
      <div class="form-group">
        <label for="published_at">Published date</label>
        <input type="date" id="published_at" name="published_at" value="<%= typeof changelog !== 'undefined' && changelog && changelog.published_at ? new Date(changelog.published_at).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
      </div>
    </div>

    <div class="editor-content">
      <textarea id="content" name="content"><%= typeof changelog !== 'undefined' && changelog ? changelog.content : '' %></textarea>
    </div>
  </form>
</div>


